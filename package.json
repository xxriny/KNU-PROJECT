{
  "name": "navigator",
  "version": "2.0.0",
  "type": "module",
  "description": "NAVIGATOR — AI-Powered Product Management & Architecture Pipeline",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "start": "electron .",
    "backend": "cd backend && python main.py --port 8765"
  },
  "dependencies": {
    "@dbml/core": "^7.1.1",
    "@monaco-editor/react": "^4.6.0",
    "@tisoap/react-flow-smart-edge": "^4.0.1",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^8.0.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pmagent.pipeline",
    "productName": "NAVIGATOR",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "overrides": {
    "dompurify": "^3.4.1"
  }
}
